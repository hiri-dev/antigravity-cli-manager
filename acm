FIRST_RENDER=1
FORCE_REDRAW=1
LAST_STATE=""

render_menu_item() {
    local idx="$1"
    local label="$2"
    local color="$3"
    local rtext ctext len
    if [[ $idx -eq $selected ]]; then
        rtext="  вқҜ  $label "
        ctext="  ${CYAN}вқҜ${NC} ${INV} $label ${NC}"
    else
        rtext="     $label "
        ctext="     ${color}$label${NC} "
    fi
    len=${#rtext}
    echo -e "${WHITE}в”Ӯ${NC}${ctext}${pad:0:$((64 - len))}${WHITE}в”Ӯ${NC}"
}

