        idx=$((idx + 1))
        render_menu_item "$idx" "[x] Exit" "${RED}"
        
        echo -e "${WHITE}в”Ӯ${NC}${pad:0:64}${WHITE}в”Ӯ${NC}"
        echo -e "${WHITE}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ${NC}\033[J"
    fi
    
    read -rsn1 -t 1 key
    read_status=$?
    
    if [[ $read_status -gt 128 ]]; then
        continue
    fi
    
    FORCE_REDRAW=0
    
    if [[ "$key" == $'\x1b' ]]; then
        read -rsn2 -t 0.1 seq
        if [[ "$seq" == "[A" ]]; then key="w"; fi
        if [[ "$seq" == "[B" ]]; then key="s"; fi
        while read -rsn1 -t 0.05; do :; done
    fi
    
    if [[ "$key" == "" || "$key" == $'\n' || "$key" == $'\r' ]]; then
        key="ENTER"
    elif [[ "$key" == "d" || "$key" == "D" || "$key" == $'\x7f' ]]; then
        if [[ $selected -lt ${#profiles[@]} ]]; then
            profile="${profiles[$selected]}"
            filename=$(basename "$profile" .json)
            
            tput cnorm
            clear
            echo -e "\n${WHITE}в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®${NC}"
            echo -e "${WHITE}в”Ӯ${NC}${BOLD}                    ANTIGRAVITY CLI MANAGER                     ${NC}${WHITE}в”Ӯ${NC}"
            echo -e "${WHITE}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ${NC}\n"
            echo -ne "  ${RED}Are you sure you want to delete '${filename}'? [y/N]: ${NC}"
            read -rn 1 conf
            if [[ "$conf" == "y" || "$conf" == "Y" ]]; then
                rm -f "$profile"
                echo -e "\n\n  ${GREEN}[+] Account deleted.${NC}"
                sleep 1
                selected=0
            fi
            tput civis
            FORCE_REDRAW=1
            continue
        fi
    elif [[ "$key" == "w" || "$key" == "W" ]]; then
        ((selected--))
        [[ $selected -lt 0 ]] && selected=$((num_opts - 1))
        FORCE_REDRAW=1
    elif [[ "$key" == "s" || "$key" == "S" ]]; then
        ((selected++))
        [[ $selected -ge $num_opts ]] && selected=0
        FORCE_REDRAW=1
    fi
    
    if [[ "$key" != "ENTER" ]]; then
        continue
    fi
    
    tput cnorm
    clear
    
    if [[ $selected -eq $((num_opts - 1)) ]]; then
        break

    elif [[ $selected -eq ${#profiles[@]} ]]; then
        has_backup=0
        if [[ -f "$TOKEN_PATH" ]]; then
            cp "$TOKEN_PATH" "${TOKEN_PATH}.bak"
            rm -f "$TOKEN_PATH"
            has_backup=1
        fi
        
        echo -e "\n${BLUE}[!] Token cleared. Opening browser for login...${NC}"
        
        rm -f "$AGY_PID_FILE"
        (
            while [[ ! -f "$TOKEN_PATH" ]]; do
                if [[ -f "$AGY_PID_FILE" ]]; then
                    read -r AGY_PID < "$AGY_PID_FILE"
                    if [[ -n "$AGY_PID" ]] && ! kill -0 "$AGY_PID" 2>/dev/null; then
                        exit 0
                    fi
                fi
                sleep 0.5
            done
            sleep 0.2
            if [[ -f "$AGY_PID_FILE" ]]; then
                read -r AGY_PID < "$AGY_PID_FILE"
                kill -TERM "$AGY_PID" 2>/dev/null
            fi
        ) &
        WATCHER_PID=$!
        
        AGY_PID_FILE="$AGY_PID_FILE" bash -c 'echo $$ > "$AGY_PID_FILE"; exec agy'
        
        kill -TERM "$WATCHER_PID" 2>/dev/null
        rm -f "$AGY_PID_FILE"
        stty sane 2>/dev/null
        
        if [[ -f "$TOKEN_PATH" ]]; then
            email=$("$HELPER_PATH" get_email "$TOKEN_PATH" 2>/dev/null)
            email=$(echo "$email" | sed 's/[^a-zA-Z0-9@._+-]/_/g')
            
            if [[ -z "$email" ]]; then
                email="account_$(date +%s)"
                echo -e "${YELLOW}[!] Could not fetch email. Using fallback: $email${NC}"
            fi
            
            profile_path="$PROFILES_DIR/${email}.json"
            cp "$TOKEN_PATH" "$profile_path"
            echo -e "\n${GREEN}[+] Account '${email}' successfully saved!${NC}"
            
            refresh_account_quota "$profile_path" >/dev/null 2>&1 &
            
            [[ $has_backup -eq 1 ]] && rm -f "${TOKEN_PATH}.bak"
        else
            echo -e "\n${RED}[-] Login failed or token not found.${NC}"
            [[ $has_backup -eq 1 ]] && mv "${TOKEN_PATH}.bak" "$TOKEN_PATH"
        fi
        
        sleep 1.5
        tput civis
        FIRST_RENDER=1
    else
        profile="${profiles[$selected]}"
        filename=$(basename "$profile" .json)
        
        "$HELPER_PATH" refresh "$profile" "$TIMEOUT" >/dev/null 2>&1
        cp "$profile" "$TOKEN_PATH"
        echo -e "\n${GREEN}[+] Switched to '${filename}'. Launching 'agy'...${NC}\n"
        
        sleep 0.5
        
        agy
        
        stty sane 2>/dev/null
        tput civis
        FIRST_RENDER=1
        FORCE_REDRAW=1
    fi
done
