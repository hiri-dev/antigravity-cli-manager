colorize_google() {
    local str="$1"
    local colors=('\033[1;33m' '\033[1;31m' '\033[1;34m' '\033[1;34m' '\033[1;32m')
    local c_idx=0
    local out=""
    for (( j=0; j<${#str}; j++ )); do
        out+="${colors[$c_idx]}${str:$j:1}"
        c_idx=$(( (c_idx + 1) % 5 ))
    done
    out+="\033[0m"
    echo -e "$out"
}

colorize_anthropic() {
    local str="$1"
    local colors=('\033[38;5;208m' '\033[1;37m')
    local c_idx=0
    local out=""
    for (( j=0; j<${#str}; j++ )); do
        out+="${colors[$c_idx]}${str:$j:1}"
        c_idx=$(( (c_idx + 1) % 2 ))
    done
    out+="\033[0m"
    echo -e "$out"
}

refresh_account_quota() {
    local profile_path="$1"
    PROFILE_PATH="$profile_path" TIMEOUT="$TIMEOUT" python3 - <<'EOF'
import os, json, urllib.request, urllib.parse, sys, base64

profile_path = os.environ.get('PROFILE_PATH')
timeout = int(os.environ.get('TIMEOUT', '3'))

try:
    with open(profile_path) as f:
        data = json.load(f)
except Exception:
    sys.exit(1)

access_token = data.get('token', {}).get('access_token')
refresh_token = data.get('token', {}).get('refresh_token')

if not access_token:
    sys.exit(1)

def query_quota(token):
    req = urllib.request.Request(
        'https://cloudcode-pa.googleapis.com/v1internal:retrieveUserQuotaSummary',
        headers={
            'Authorization': f'Bearer {token}',
            'Content-Type': 'application/json',
            'User-Agent': 'vscode/1.X.X (Antigravity/4.2.4)'
        },
        data=json.dumps({}).encode('utf-8'),
        method='POST'
    )
    with urllib.request.urlopen(req, timeout=timeout) as res:
        return json.loads(res.read().decode('utf-8'))

quota_data = None
try:
    quota_data = query_quota(access_token)
except Exception:
    if refresh_token:
        try:
            sec_b64 = 'R0NTUFgtSzU4RldSNDg2TGRMSjFtTEI4c1hDNHo2cURBZg=='
            req_refresh = urllib.request.Request(
                'https://oauth2.googleapis.com/token',
                data=urllib.parse.urlencode({
                    'client_id': '1071006060591-tmhssin2h21lcre235vtolojh4g403ep.apps.googleusercontent.com',
                    'client_secret': base64.b64decode(sec_b64).decode('utf-8'),
                    'refresh_token': refresh_token,
                    'grant_type': 'refresh_token'
                }).encode('utf-8'),
                method='POST'
            )
            with urllib.request.urlopen(req_refresh, timeout=timeout) as res_ref:
                ref_res_data = json.loads(res_ref.read().decode('utf-8'))
                new_token = ref_res_data.get('access_token')
                if new_token:
                    access_token = new_token
                    data['token']['access_token'] = new_token
                    try:
                        quota_data = query_quota(access_token)
                        with open(profile_path, 'w') as f:
                            json.dump(data, f)
                    except Exception:
                        pass
        except Exception:
            pass

if not quota_data:
    sys.exit(1)

try:
    g_pct = None
    c_pct = None
    
    for group in quota_data.get('groups', []):
        display_name = group.get('displayName', '').lower()
        
        weekly_frac = None
        fiveh_frac = None
        for b in group.get('buckets', []):
            w = b.get('window', '').lower()
            if w == 'weekly':
                weekly_frac = b.get('remainingFraction')
            elif w == '5h':
                fiveh_frac = b.get('remainingFraction')
                
        if weekly_frac is None:
            weekly_frac = 1.0
        if fiveh_frac is None:
            fiveh_frac = 1.0
            
        pct = 0
        if weekly_frac > 0.001:
            pct = int(fiveh_frac * 100)
            
        if 'gemini' in display_name:
            g_pct = pct
        elif 'claude' in display_name or 'gpt' in display_name or '3p' in display_name:
            c_pct = pct

    if g_pct is not None or c_pct is not None:
        data['g_pct'] = g_pct if g_pct is not None else 0
        data['c_pct'] = c_pct if c_pct is not None else 0
        data['quota_percent'] = data['g_pct'] + data['c_pct']
        with open(profile_path, 'w') as f:
            json.dump(data, f)
        sys.exit(0)
except Exception:
    pass

sys.exit(1)
EOF
}

