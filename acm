#!/usr/bin/env bash

RED='\033[0;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
BLUE='\033[1;34m'
CYAN='\033[1;36m'
WHITE='\033[1;37m'
BOLD='\033[1m'
NC='\033[0m'
INV='\033[7m'

TOKEN_PATH="$HOME/.gemini/antigravity-cli/antigravity-oauth-token"
CONFIG_DIR="$HOME/.config/acm"
CONFIG_PATH="$CONFIG_DIR/config.json"
PROFILES_DIR="$CONFIG_DIR/profiles"
AGY_PID_FILE="$CONFIG_DIR/agy.pid"
HELPER_PATH="$(dirname "$0")/acm_helper.py"

MIGRATION_MARKER="$CONFIG_DIR/.migrated"
if [[ ! -f "$MIGRATION_MARKER" ]]; then
    LEGACY_PROFILES_DIR="$HOME/antigravity-cli-manager/profiles"
    if [[ -d "$LEGACY_PROFILES_DIR" ]]; then
        mkdir -p "$PROFILES_DIR"
        cp -rn "$LEGACY_PROFILES_DIR"/*.json "$PROFILES_DIR"/ 2>/dev/null
    fi
    touch "$MIGRATION_MARKER" 2>/dev/null
fi

mkdir -p "$PROFILES_DIR"
mkdir -p "$(dirname "$TOKEN_PATH")"
mkdir -p "$CONFIG_DIR"


if [[ "${1:-}" == "rotate" ]]; then
    NEW_PROFILE=$("$HELPER_PATH" rotate "$TOKEN_PATH" "$PROFILES_DIR" 2>/dev/null)
    if [[ -n "$NEW_PROFILE" ]]; then
        echo "Auto-rotated to: $NEW_PROFILE"
    fi
    exit 0
fi

if [[ "${1:-}" == "run" ]]; then
    if [[ $# -lt 2 ]]; then
        echo "Usage: acm run <command...>"
        exit 1
    fi
    "$HELPER_PATH" rotate "$TOKEN_PATH" "$PROFILES_DIR" >/dev/null 2>&1
    shift
    exec "$@"
fi

if [[ ! -f "$CONFIG_PATH" ]]; then
    cat <<JSON > "$CONFIG_PATH"
{
    "show_ascii_art": true,
    "timeout_seconds": 3
}
JSON
fi

SHOW_ART=$("$HELPER_PATH" get_config "$CONFIG_PATH" show_ascii_art True)
TIMEOUT=$("$HELPER_PATH" get_config "$CONFIG_PATH" timeout_seconds 3)

trap "tput cnorm; exit" INT TERM EXIT

tput civis

selected=0

colorize_google() {
    local str="$1"
    local colors=('\033[1;33m' '\033[1;31m' '\033[1;34m' '\033[1;34m' '\033[1;32m')
    local c_idx=0
    local out=""
    for (( j=0; j<${#str}; j++ )); do
        out+="${colors[$c_idx]}${str:$j:1}"
        c_idx=$(( (c_idx + 1) % 5 ))
    done
    out+="\033[0m"
    echo -e "$out"
}

colorize_anthropic() {
    local str="$1"
    local colors=('\033[38;5;208m' '\033[1;37m')
    local c_idx=0
    local out=""
    for (( j=0; j<${#str}; j++ )); do
        out+="${colors[$c_idx]}${str:$j:1}"
        c_idx=$(( (c_idx + 1) % 2 ))
    done
    out+="\033[0m"
    echo -e "$out"
}

refresh_account_quota() {
    "$HELPER_PATH" refresh "$1" "$TIMEOUT"
}

run_refresh_quotas_startup() {
    for profile in "$PROFILES_DIR"/*.json; do
        [[ -f "$profile" ]] && refresh_account_quota "$profile" >/dev/null 2>&1 &
    done
}

